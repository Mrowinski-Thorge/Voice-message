{
  "expo": {
    "name": "VoiceNote",
    "slug": "voiceanalyzer",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./icon.png",
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "scheme": "voicenote",
    "android": {
      "package": "com.thorge.voicenote",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-share-intent",
        {
          "androidIntentFilters": ["audio/*"]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24
          }
        }
      ]
    ]
  }
}
