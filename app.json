{
  "expo": {
    "name": "Gemini Studio",
    "slug": "gemini-studio",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./icon.png",
    "scheme": "geministudio",
    "splash": {
      "backgroundColor": "#07090d"
    },
    "extra": {
      "eas": {
        "projectId": "88cab564-1003-4e1d-88db-9acae7f5e6a9"
      }
    },
    "android": {
      "package": "com.thorge.geministudio",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./adaptive-icon.png",
        "backgroundColor": "#07090d"
      },
      "permissions": [
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "buildToolsVersion": "34.0.0"
          }
        }
      ]
    ]
  }
